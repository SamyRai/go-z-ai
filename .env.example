# Z.AI API Configuration
# Copy this file to .env and fill in your API key

# Your Z.AI API Key (required)
ZAI_API_KEY=your_api_key_here

# API Base URL (optional, defaults to production endpoint)
# ZAI_API_BASE_URL=https://api.z.ai/api/paas/v4

# Regional gateway for monitor/biz/agents (optional: global | china). Use
# "china" if your key was issued on open.bigmodel.cn so quota/usage and
# account-info calls land on the matching host. Does not change the chat base
# URL (set ZAI_API_BASE_URL for that). Aliases: cn, bigmodel, west.
# ZAI_REGION=global

# Environment (optional: development, production)
# ZAI_ENV=development

# --- Multiple accounts ---
# If you switch between more than one Z.AI account (e.g. pay-as-you-go and a
# GLM Coding Plan subscription), don't hand-edit the keys above — use the
# `accounts` command instead, which stores credentials in
# ~/.config/zai-client/accounts.json and derives the correct base URL from
# each account's type automatically:
#
#   go-z-ai accounts add work --api-key <key>   # type auto-detected
#   go-z-ai accounts add personal --api-key <key>
#   go-z-ai accounts use work                    # switch the active account
#   go-z-ai accounts list                        # see all accounts
#   go-z-ai accounts quota                       # check usage/reset times for all accounts
#   go-z-ai accounts usage                       # token/tool usage heat map for all accounts
#
# ZAI_API_KEY/ZAI_API_BASE_URL above still take precedence when set, so this
# is purely additive — you don't need to remove them to use `accounts`.
